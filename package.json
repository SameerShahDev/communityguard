{
  "name": "communityguard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run postbuild",
    "postbuild": "node -e \"const fs=require('fs'), path=require('path'); const src='.vercel/output/static', dst='dist'; if(fs.existsSync(dst)) fs.rmSync(dst,{recursive:true}); if(fs.existsSync(src)) fs.cpSync(src,dst,{recursive:true,force:true}); console.log('Copied build output to dist');\"",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.26.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "shadcn": "^4.1.2",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "typescript": "^5"
  }
}
